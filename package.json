{
  "name": "@regressionbot/playwright",
  "version": "0.2.0",
  "description": "Playwright integration client for RegressionBot parallel cloud visual regression comparisons",
  "repository": {
    "type": "git",
    "url": "https://github.com/RegressionBot/playwright-sdk"
  },
  "Description": "Created package.json for @regressionbot/playwright SDK workspace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global-setup": {
      "types": "./dist/global-setup.d.ts",
      "default": "./dist/global-setup.js"
    },
    "./global-teardown": {
      "types": "./dist/global-teardown.d.ts",
      "default": "./dist/global-teardown.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "keywords": [
    "playwright",
    "visual",
    "regression",
    "testing",
    "regressionbot"
  ],
  "author": "RegressionBot Team",
  "license": "Apache-2.0",
  "peerDependencies": {
    "@playwright/test": "^1.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
